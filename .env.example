# ─────────────────────────────────────────────────────────────
# Phone License site — environment variables
# Copy this file to `.env` and fill in real values as they arrive.
# Everything here is client-side (the browser needs it), so every
# var is PUBLIC_*. Nothing secret lives here — Kajabi holds the secrets.
# The site builds and runs fine with these left as placeholders.
# ─────────────────────────────────────────────────────────────

# Zapier/Make "Catch Hook" URL. Every lead form POSTs here.
# Get it: Zapier → new Zap → "Webhooks by Zapier → Catch Hook" → copy URL.
PUBLIC_WEBHOOK_URL=

# Meta (Facebook) Pixel ID — a ~15-digit number from Meta Events Manager.
PUBLIC_META_PIXEL_ID=

# Optional: Google Analytics 4 Measurement ID (G-XXXXXXXXXX). Leave blank to skip.
PUBLIC_GA4_ID=

# Church "planning something bigger?" destination — a Calendly URL or mailto:.
PUBLIC_CALENDLY_URL=
