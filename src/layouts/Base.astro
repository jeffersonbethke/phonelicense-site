---
/**
 * Base page layout. Loads fonts + tokens, injects integration config for the
 * client libs, boots the Meta Pixel (if configured), captures first-touch
 * UTMs, and wires the delegated Kajabi-checkout click handler.
 *
 * Props: title, description, viewContent (fire ViewContent for key pages).
 */
import '../styles/tokens.css';
import '../styles/global.css';
import { site } from '../config/site';
import { promotedEvent } from '../config/events';
import AnnouncementBar from '../components/AnnouncementBar.astro';

interface Props {
  title?: string;
  description?: string;
  viewContent?: string | boolean;
  ogImage?: string;
  /** Hide the site-wide announcement bar on this page (e.g. /quiz). */
  announcement?: boolean;
  /** Keep this page out of search engines (e.g. /admin/config). */
  noindex?: boolean;
}

// Pre-paint dismissal key for the promoted event (avoids flash + layout shift).
const promo = promotedEvent();
const barKey = promo ? `pl_bar_${promo.slug}_${promo.state}` : '';
const {
  title = `${site.name} — ${site.tagline}`,
  description = 'Earn the phone. Keep the trust. A calm, parent-to-parent plan for the first phone — or a fresh start on the one they already have.',
  viewContent = false,
  announcement = true,
  noindex = false,
} = Astro.props;

const vc = viewContent === true ? '' : typeof viewContent === 'string' ? viewContent : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Load fonts async so they never block first paint. The system-font
        fallback in our stack makes the swap effectively invisible. */}
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      />
    </noscript>

    {/* Integration config for the client libs (safe if blank). */}
    <script
      is:inline
      define:vars={{ webhookUrl: site.webhookUrl, pixelId: site.metaPixelId }}
    >
      window.__PL = { webhookUrl: webhookUrl, pixelId: pixelId };
      window._plPixelId = pixelId;
    </script>

    {/* Announcement bar: hide pre-paint if this event+state was dismissed. */}
    {
      announcement && barKey && (
        <script is:inline define:vars={{ barKey }}>
          {`try{if(localStorage.getItem(barKey)==='1')document.documentElement.classList.add('abar-hide');}catch(e){}`}
        </script>
      )
    }

    {/* Meta Pixel — only boots when an id is configured. */}
    {
      site.metaPixelId && (
        <script is:inline define:vars={{ pixelId: site.metaPixelId }}>
          {`!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init', pixelId);fbq('track','PageView');`}
        </script>
      )
    }
  </head>
  <body>
    {announcement && <AnnouncementBar />}
    <slot />

    {/* Boot client libs: UTM capture, optional ViewContent, Kajabi clicks. */}
    <script>
      import { captureUtms, appendUtms } from '../lib/utm';
      import { viewContent as fireViewContent, initiateCheckout } from '../lib/pixel';

      // 1. First-touch UTM capture.
      captureUtms();

      // 2. Rewrite every Kajabi CTA href with persisted UTMs (skip TODO links).
      document.querySelectorAll<HTMLAnchorElement>('a[data-kajabi]').forEach((a) => {
        if (a.dataset.todo === 'true') return;
        a.href = appendUtms(a.href);
      });

      // 3. Fire InitiateCheckout on Kajabi CTA clicks.
      document.addEventListener('click', (e) => {
        const a = (e.target as HTMLElement)?.closest?.('a[data-kajabi]');
        if (!a) return;
        const value = Number((a as HTMLElement).dataset.offerValue || 0);
        const name = (a as HTMLElement).dataset.offerName || 'offer';
        initiateCheckout(value, name);
      });

      // 4. ViewContent on key pages (opt-in via layout prop).
      const vcName = document.documentElement.getAttribute('data-viewcontent');
      if (vcName !== null) fireViewContent(vcName || undefined);
    </script>

    {vc !== null && <script is:inline define:vars={{ vc }}>{`document.documentElement.setAttribute('data-viewcontent', vc);`}</script>}
  </body>
</html>
