---
/**
 * Hero iPhone mockup with floating badge cards — recreates the original
 * homepage hero centerpiece (the Phone License app on a phone, ringed by
 * "6 modules / License ID / Family Agreement" cards).
 */
const modules = [
  { name: 'Rules of the Road', pct: 100, done: true },
  { name: 'Night Driving', pct: 62, done: false, current: true },
  { name: 'Hazards & Car Crash', pct: 0, done: false },
  { name: 'Maintenance · Renewal', pct: 0, done: false },
];
---

<div class="hero-mock">
  {/* floating cards */}
  <div class="chip chip-modules">
    <span class="ic" aria-hidden="true">▤</span>
    <div><b>6 modules</b><span>Video, quiz, road test</span></div>
  </div>
  <div class="chip chip-license">
    <span class="ic" aria-hidden="true">✓</span>
    <div><b>License ID</b><span>Verifiable + renewable</span></div>
  </div>
  <div class="chip chip-agreement">
    <span class="ic" aria-hidden="true">✍</span>
    <div><b>Family Agreement</b><span>Signed, not just talked about</span></div>
  </div>

  {/* phone */}
  <div class="phone">
    <div class="notch" aria-hidden="true"></div>
    <div class="screen">
      <div class="app-top">
        <span class="mark" aria-hidden="true"></span>
        <span class="app-title">Phone License</span>
      </div>
      <p class="app-sub mono">Earn the phone · keep the trust</p>

      <div class="progress-card">
        <div class="pc-head">
          <span class="mono">Week 4 of 6</span>
          <span class="pc-pct">66%</span>
        </div>
        <div class="bar"><span style="width:66%"></span></div>
        <p class="pc-now">Rules of the Road → <b>Night Driving</b></p>
      </div>

      <ul class="mod-list">
        {modules.map((m) => (
          <li class:list={[m.done && 'done', m.current && 'current']}>
            <span class="dot" aria-hidden="true">{m.done ? '✓' : ''}</span>
            <span class="mn">{m.name}</span>
            <span class="mp mono">{m.pct}%</span>
          </li>
        ))}
      </ul>

      <button class="resume" type="button">Resume Module 4</button>
      <p class="roadtest mono">Road test · 6 min</p>
    </div>
  </div>
</div>

<style>
  .hero-mock {
    position: relative;
    width: 100%;
    max-width: 340px;
    margin: 40px auto 0;
    padding-block: 20px;
  }
  .phone {
    position: relative;
    width: 232px;
    margin: 0 auto;
    background: #0f0f10;
    border-radius: 40px;
    padding: 10px;
    box-shadow: var(--shadow-lg);
    z-index: 2;
  }
  .notch {
    position: absolute;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    width: 74px;
    height: 20px;
    background: #0f0f10;
    border-radius: 12px;
    z-index: 3;
  }
  .screen {
    background: var(--bg-2);
    border-radius: 30px;
    padding: 34px 16px 18px;
    min-height: 460px;
  }
  .app-top {
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .mark {
    width: 18px;
    height: 18px;
    border-radius: 6px;
    background: linear-gradient(135deg, var(--blue), var(--blue-deep));
    flex: none;
  }
  .app-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .app-sub {
    font-size: 8px;
    color: var(--muted);
    margin-top: 4px;
  }
  .progress-card {
    background: #fff;
    border-radius: 14px;
    padding: 12px;
    margin-top: 14px;
    box-shadow: var(--shadow-sm);
  }
  .pc-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 10px;
    color: var(--muted);
  }
  .pc-pct {
    color: var(--blue-deep);
    font-weight: 700;
    font-family: var(--font-display);
  }
  .bar {
    height: 6px;
    background: var(--line);
    border-radius: 999px;
    margin: 8px 0;
    overflow: hidden;
  }
  .bar span {
    display: block;
    height: 100%;
    background: var(--blue);
    border-radius: 999px;
  }
  .pc-now {
    font-size: 10px;
    color: var(--ink-2);
  }
  .mod-list {
    list-style: none;
    margin-top: 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .mod-list li {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    border-radius: 10px;
    padding: 9px 11px;
    font-size: 11px;
    color: var(--ink-2);
  }
  .mod-list .dot {
    width: 15px;
    height: 15px;
    border-radius: 50%;
    border: 1.5px solid var(--line-2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    color: #fff;
    flex: none;
  }
  .mod-list li.done .dot {
    background: var(--blue);
    border-color: var(--blue);
  }
  .mod-list li.current {
    outline: 1.5px solid var(--blue-tint-2);
  }
  .mod-list li.current .dot {
    border-color: var(--blue);
  }
  .mn {
    flex: 1;
  }
  .mp {
    color: var(--muted);
    font-size: 9px;
  }
  .resume {
    width: 100%;
    margin-top: 14px;
    background: var(--ink);
    color: #fff;
    border: none;
    border-radius: 999px;
    padding: 11px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
  }
  .roadtest {
    text-align: center;
    font-size: 8px;
    color: var(--muted);
    margin-top: 8px;
  }

  /* Floating chips */
  .chip {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 8px 11px;
    box-shadow: var(--shadow-md);
    z-index: 3;
  }
  .chip b {
    display: block;
    font-size: 11px;
    color: var(--ink);
    font-family: var(--font-display);
    letter-spacing: -0.01em;
  }
  .chip span:not(.ic) {
    font-size: 9px;
    color: var(--muted);
  }
  .chip .ic {
    width: 22px;
    height: 22px;
    border-radius: 7px;
    background: var(--blue-tint);
    color: var(--blue-deep);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    flex: none;
  }
  .chip-modules {
    top: 40px;
    left: -6px;
  }
  .chip-license {
    top: 128px;
    right: -6px;
  }
  .chip-agreement {
    bottom: 44px;
    left: -12px;
  }
  @media (max-width: 480px) {
    .chip-modules {
      left: -4px;
      top: 20px;
    }
    .chip-license {
      right: -4px;
    }
    .chip-agreement {
      left: -4px;
    }
    .chip b {
      font-size: 10px;
    }
  }
</style>
