---
/**
 * Sticky floating pill nav with translucent blur backdrop.
 * `yearMark` shows the edition (e.g. "2026") next to the brand on event pages.
 * `cta` renders a dark pill on the right; `anchors` are in-page links.
 */
import BrandMark from './BrandMark.astro';
import { nav as siteNav } from '../config/site';

interface Props {
  yearMark?: string;
  anchors?: { label: string; href: string }[];
  cta?: { label: string; href: string } | null;
}
const { yearMark, anchors, cta } = Astro.props;
const links = anchors ?? siteNav.map((n) => ({ label: n.label, href: n.href }));
---

<header class="nav-shell">
  <nav class="pill" aria-label="Primary">
    <a href="/" class="home">
      <BrandMark />
      {yearMark && <span class="year">{yearMark}</span>}
    </a>
    <div class="links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>
    {
      cta && (
        <a href={cta.href} class="btn btn-dark cta">
          {cta.label}
        </a>
      )
    }
  </nav>
</header>

<style>
  .nav-shell {
    position: sticky;
    top: 12px;
    z-index: 100;
    padding-inline: 16px;
  }
  .pill {
    max-width: var(--maxw);
    margin-inline: auto;
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 9px 9px 9px 16px;
    border-radius: var(--r-pill);
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-sm);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    backdrop-filter: saturate(180%) blur(20px);
  }
  .home {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .year {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--muted);
    padding: 2px 7px;
    border: 1px solid var(--line-2);
    border-radius: var(--r-pill);
  }
  .links {
    display: none;
    align-items: center;
    gap: 20px;
    margin-inline: auto;
  }
  .links a {
    font-size: 14.5px;
    color: var(--ink-2);
  }
  .links a:hover {
    color: var(--ink);
  }
  .cta {
    padding: 10px 18px;
    font-size: 14px;
  }
  @media (min-width: 760px) {
    .links {
      display: flex;
    }
  }
</style>
