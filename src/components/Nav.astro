---
/**
 * Sticky floating pill nav with translucent blur backdrop.
 * `yearMark` shows the edition (e.g. "2026") next to the brand on event pages.
 * `cta` renders a dark pill on the right; `anchors` are in-page links.
 * On mobile the links collapse into a hamburger panel.
 */
import BrandMark from './BrandMark.astro';
import { nav as siteNav } from '../config/site';

interface Props {
  yearMark?: string;
  anchors?: { label: string; href: string }[];
  cta?: { label: string; href: string } | null;
}
const { yearMark, anchors, cta } = Astro.props;
const links = anchors ?? siteNav.map((n) => ({ label: n.label, href: n.href }));
---

<header class="nav-shell">
  <nav class="pill" aria-label="Primary">
    <a href="/" class="home">
      <BrandMark />
      {yearMark && <span class="year">{yearMark}</span>}
    </a>
    <div class="links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>
    {
      cta && (
        <a href={cta.href} class="btn btn-dark cta">
          {cta.label}
        </a>
      )
    }
    <button class="burger" id="nav-burger" aria-label="Menu" aria-expanded="false" aria-controls="nav-menu">
      <span></span><span></span>
    </button>
  </nav>

  <div class="menu" id="nav-menu" hidden>
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
    {cta && <a href={cta.href} class="btn btn-dark menu-cta">{cta.label}</a>}
  </div>
</header>

<style>
  .nav-shell {
    position: sticky;
    top: 12px;
    z-index: 100;
    padding-inline: 16px;
  }
  .pill {
    max-width: var(--maxw);
    margin-inline: auto;
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 9px 9px 9px 16px;
    border-radius: var(--r-pill);
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-sm);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    backdrop-filter: saturate(180%) blur(20px);
  }
  .home {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-right: auto;
  }
  .year {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--muted);
    padding: 2px 7px;
    border: 1px solid var(--line-2);
    border-radius: var(--r-pill);
  }
  .links {
    display: none;
    align-items: center;
    gap: 20px;
    margin-inline: auto;
  }
  .links a {
    font-size: 14.5px;
    color: var(--ink-2);
    white-space: nowrap;
  }
  .links a:hover {
    color: var(--ink);
  }
  .cta {
    padding: 10px 18px;
    font-size: 14px;
  }

  /* Hamburger (mobile only) */
  .burger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 0 10px;
    background: none;
    border: none;
    cursor: pointer;
  }
  .burger span {
    display: block;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .burger[aria-expanded='true'] span:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }
  .burger[aria-expanded='true'] span:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }

  .menu {
    max-width: var(--maxw);
    margin: 8px auto 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px;
    border-radius: var(--r-md);
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-md);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    backdrop-filter: saturate(180%) blur(20px);
  }
  .menu a {
    padding: 12px 14px;
    font-size: 16px;
    color: var(--ink-2);
    border-radius: var(--r-sm);
  }
  .menu a:hover {
    background: var(--bg-2);
  }
  .menu-cta {
    margin-top: 6px;
    justify-content: center;
    color: #fff;
  }

  @media (min-width: 760px) {
    .links {
      display: flex;
    }
    .burger,
    .menu {
      display: none !important;
    }
  }
</style>

<script>
  const burger = document.getElementById('nav-burger');
  const menu = document.getElementById('nav-menu');
  if (burger && menu) {
    burger.addEventListener('click', () => {
      const open = burger.getAttribute('aria-expanded') === 'true';
      burger.setAttribute('aria-expanded', String(!open));
      menu.hidden = open;
    });
    // Close when a link is tapped.
    menu.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        burger.setAttribute('aria-expanded', 'false');
        menu.hidden = true;
      })
    );
  }
</script>
