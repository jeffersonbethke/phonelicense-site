---
/**
 * Sticky mobile CTA bar — shows only under 900px. Translucent blur, safe-area
 * padding. `line` is the state copy; the CTA is a slot (usually a KajabiLink).
 */
interface Props {
  title: string;
  line: string;
}
const { title, line } = Astro.props;
---

<div class="sticky-cta">
  <div class="text">
    <strong>{title}</strong>
    <span>{line}</span>
  </div>
  <div class="action"><slot /></div>
</div>

<style>
  .sticky-cta {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 90;
    display: none;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
    background: rgba(255, 255, 255, 0.85);
    border-top: 1px solid var(--line);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    backdrop-filter: saturate(180%) blur(20px);
  }
  .text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .text strong {
    font-size: 14px;
    color: var(--ink);
  }
  .text span {
    font-size: 12px;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .action :global(.btn) {
    padding: 11px 16px;
    font-size: 14px;
    white-space: nowrap;
  }
  @media (max-width: 899px) {
    .sticky-cta {
      display: flex;
    }
  }
</style>
