---
/**
 * Sales homepage — the ORIGINAL page, verbatim (its own HTML + 58KB stylesheet
 * extracted from the original build), with the requested additions injected
 * using the original's own CSS classes so spacing/design match exactly.
 *
 * Additions: funnel nav (done in body.html), BE HONEST, Two-Door, Live Events,
 * Workshop showcase, footer PDF capture, promo modal, quiz CTAs, and buy-button
 * wiring to the Kajabi offer + pixel/UTM.
 */
import homeCss from '../styles/home.css?raw';
import rawBody from '../home/body.html?raw';
import { site } from '../config/site';
import { offers } from '../config/offers';
import { events } from '../config/events';
import { conference } from '../config/event-content';

const course = offers.course;
const conf = events['conference'];
const MONTHS = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
const rows = Object.values(events).filter((e) => e.state !== 'replay').sort((a, b) => a.dateISO.localeCompare(b.dateISO));

// ── Addition sections, styled with the original classes (.container/.eyebrow/.accent) ──
const beHonest = `
<section class="add-felt">
  <div class="container">
    <p class="eyebrow">Be honest</p>
    ${conference.feltNeed.map((q, i) => `<p class="add-fq" style="opacity:${1 - i * 0.2}">${q}</p>`).join('')}
    <p class="add-fturn">You're not failing. The terrain changed — and nobody briefed you. <span class="accent">That's exactly what Phone License is for.</span></p>
  </div>
</section>`;

const twoDoor = `
<section>
  <div class="container">
    <div class="section-head"><p class="eyebrow">Two doors, one path</p><h2>Two kinds of families end up here. <span class="accent">It works for both.</span></h2></div>
    <div class="add-doors">
      <div class="add-card">
        <p class="add-k">First phone</p><h3>The path to a confident yes.</h3>
        <p>You haven't handed it over yet — and you want the first phone to start on trust, not guesswork. Phone License gives you the agreement, the settings, and the handoff conversation so you can say yes without second-guessing.</p>
      </div>
      <div class="add-card hl">
        <p class="add-k">A fresh start</p><h3>Start over without taking it away.</h3>
        <p>They've had the phone a while and the boundaries slipped. Here's the relief: <b>nothing gets confiscated.</b> The phone gets re-issued under a new agreement they earn — calm, clear, and mutual.</p>
      </div>
    </div>
  </div>
</section>`;

const liveEvents = `
<section class="add-live">
  <div class="container">
    <div class="section-head"><p class="eyebrow" style="color:var(--blue)">Live events · The 2026 Season</p>
      <h2 style="color:#fff">We also run a few <span class="accent">live intensives</span> a year.</h2>
      <p class="add-lsub">Two virtual summits and one in-person workshop, every year — the annual briefing on what actually changed, for parents who don't want to figure it out alone.</p></div>
    <div class="add-rows">
      ${rows.map((e) => {
        const [, m, d] = e.dateISO.split('-').map(Number);
        const kind = e.kind === 'workshop' ? 'In-person workshop · once a year' : `Live virtual summit · ${e.season === 'fall' ? 'Fall' : 'Spring'} ${e.edition}`;
        return `<a class="add-row" href="/${e.slug}"><span class="add-date"><span class="mo">${MONTHS[(m||1)-1]}</span><span class="dy">${d}</span></span><span class="add-mid"><span class="add-kind">${kind}</span><span class="add-title">${e.title}${e.themeLine ? ': ' + e.themeLine : ''}</span></span><span class="add-arrow">→</span></a>`;
      }).join('')}
    </div>
    <div class="add-lfoot"><span class="add-note">One workshop a year · capped at 200 couples</span><a href="/events" class="btn-ghost">See the full season →</a></div>
  </div>
</section>`;

const workshop = `
<section class="add-ws">
  <img class="add-ws-bg" src="/assets/room-wide.jpg" alt="" loading="lazy" decoding="async" />
  <div class="add-ws-scrim"></div>
  <div class="container add-ws-in">
    <p class="eyebrow" style="color:var(--blue)">The ${conf.edition} in-person workshop · once a year</p>
    <h2 style="color:#fff">Spend one day with us. <span class="accent">Parent the whole year on purpose.</span></h2>
    <p class="add-ws-lede">${conf.title} is the annual, in-person briefing for parents — both of you in one room in ${conf.city}, then a long-table supper in Leipers Fork. It's the day couples talk about on the drive home.</p>
    <p class="add-ws-meta">${conf.dateDisplay} · ${conf.venue} · Capped at ${conf.capacity} couples</p>
    <div class="add-ws-cta"><a href="/conference" class="btn-white">See the full day →</a></div>
  </div>
</section>`;

const pdfCapture = `
<section class="add-pdf">
  <div class="container add-pdf-grid">
    <div><p class="eyebrow">Free download</p><h3>The Family Phone Contract</h3><p class="add-pdf-sub">The one-page agreement thousands of families sign before the phone changes hands — first phone or a fresh start. We'll email it over.</p></div>
    <form class="add-form" data-lead data-tags="Lead - Contract PDF" data-pixel="Contract PDF" data-next="/quiz" data-next-label="See if they're ready — take the free quiz →" data-title="On its way, {name}." data-body="Check your inbox for the Family Phone Contract.">
      <input type="text" name="name" placeholder="First name" autocomplete="given-name" />
      <input type="email" name="email" placeholder="Email address" required autocomplete="email" />
      <button type="submit" class="btn-dark">Email me the contract</button>
      <p class="add-fine">No spam · one email · unsubscribe anytime.</p>
      <p class="add-err" role="alert" hidden></p>
    </form>
  </div>
</section>`;

const promoModal = `
<div class="add-modal" id="promo-modal">
  <div class="add-scrim" data-close></div>
  <div class="add-dialog" role="dialog" aria-modal="true">
    <button class="add-x" data-close aria-label="Close">×</button>
    <div data-variant="value" hidden>
      <p class="eyebrow">Free · 3 minutes</p><h3>Is your kid ready for a phone?</h3>
      <p>Take the free Smartphone Readiness Assessment. In 3 minutes you'll see exactly where they are — first phone or a fresh start — plus a personalized plan. No email needed to start.</p>
      <a href="/quiz" class="btn-dark" style="width:100%">See if they're ready →</a><button class="add-dismiss" data-close>Maybe later</button>
    </div>
    <div data-variant="exit" hidden>
      <p class="eyebrow">Before you go</p><h3>Don't leave guessing.</h3>
      <p>The free 3-minute assessment tells you whether they're ready — and the first move to make, whether it's their first phone or a reset.</p>
      <a href="/quiz" class="btn-dark" style="width:100%">Take the free quiz →</a><button class="add-dismiss" data-close>No thanks, keep reading</button>
    </div>
  </div>
</div>`;

// ── Inject additions into the verbatim original body at the original anchors ──
let body = rawBody;
// buy buttons → Kajabi course offer (UTM + InitiateCheckout wired client-side)
body = body.replaceAll('<a href="#pricing" class="cta">Start — $49</a>', `<a href="${course.url}" class="cta" data-kajabi data-offer-value="${course.pixelValue}" data-offer-name="Phone License course"${course.url.startsWith('#') ? ' data-todo="true"' : ''}>Start — $49</a>`);
// after hero
body = body.replace('<!-- ============================ FELT NEED', beHonest + twoDoor + '\n<!-- ============================ FELT NEED');
// live events before curriculum
body = body.replace('<!-- ============================ CURRICULUM', liveEvents + '\n<!-- ============================ CURRICULUM');
// workshop before pricing
body = body.replace('<!-- ============================ PRICING', workshop + '\n<!-- ============================ PRICING');
// footer PDF capture before footer
body = body.replace('<!-- ============================ FOOTER', pdfCapture + '\n<!-- ============================ FOOTER');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Phone License — Earn the phone. Keep the trust.</title>
    <meta name="description" content="A parent + teen course that turns phone access into earned trust — first phone or a fresh start on the one they already have." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style is:inline set:html={homeCss}></style>

    {/* Integration config for the client libs */}
    <script is:inline define:vars={{ webhookUrl: site.webhookUrl, pixelId: site.metaPixelId }}>
      window.__PL = { webhookUrl: webhookUrl, pixelId: pixelId };
      window._plPixelId = pixelId;
    </script>
    {site.metaPixelId && (
      <script is:inline define:vars={{ pixelId: site.metaPixelId }}>
        {`!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init', pixelId);fbq('track','PageView');`}
      </script>
    )}
  </head>
  <body>
    <Fragment set:html={body} />
    <Fragment set:html={promoModal} />

    {/* ── Styles for the injected additions (original tokens/classes) ── */}
    <style is:inline>{`
      .add-felt{background:var(--bg-2);text-align:center}
      .add-fq{font-family:var(--font-display,Inter);font-weight:600;font-size:clamp(21px,3.6vw,32px);letter-spacing:-.03em;color:var(--ink);line-height:1.15;margin-top:12px}
      .add-fturn{max-width:640px;margin:30px auto 0;font-size:clamp(17px,2.2vw,20px);color:var(--ink-2)}
      .add-doors{display:grid;gap:20px;margin-top:40px}
      @media(min-width:720px){.add-doors{grid-template-columns:1fr 1fr}}
      .add-card{background:var(--surface,#fff);border:1px solid var(--line,rgba(15,15,16,.08));border-radius:22px;padding:28px;box-shadow:0 1px 2px rgba(15,15,16,.04),0 4px 14px rgba(15,15,16,.05)}
      .add-card.hl{background:var(--blue-tint,#eef2fa);border-color:var(--blue-tint-2,#dde7f7)}
      .add-card h3{margin:8px 0}
      .add-card p:last-child{color:var(--ink-2);margin-top:8px}
      .add-k{font-family:var(--font-mono,monospace);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--blue-deep,#3a68b5)}
      .add-live{background:var(--ink);color:#fff}
      .add-live .add-lsub{color:rgba(255,255,255,.72);max-width:580px;margin:12px auto 0}
      .add-rows{margin-top:28px}
      .add-row{display:grid;grid-template-columns:64px 1fr auto;align-items:center;gap:16px;padding:22px 4px;border-top:1px solid rgba(255,255,255,.12);color:#fff;text-decoration:none}
      .add-row:hover{background:rgba(255,255,255,.04)}
      .add-date{display:flex;flex-direction:column;align-items:center;line-height:1}
      .add-date .mo{font-family:var(--font-mono,monospace);font-size:11px;letter-spacing:.1em;color:var(--blue,#4f83cc)}
      .add-date .dy{font-family:var(--font-display,Inter);font-weight:700;font-size:30px;letter-spacing:-.03em}
      .add-mid{display:flex;flex-direction:column;gap:3px;min-width:0}
      .add-kind{font-family:var(--font-mono,monospace);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.55)}
      .add-title{font-family:var(--font-display,Inter);font-weight:600;font-size:17px;letter-spacing:-.02em}
      .add-arrow{color:rgba(255,255,255,.6);font-size:18px}
      .add-lfoot{display:flex;flex-wrap:wrap;gap:14px;align-items:center;justify-content:space-between;padding-top:26px}
      .add-note{font-family:var(--font-mono,monospace);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.5)}
      .add-ws{position:relative;overflow:hidden;color:#fff;background:var(--ink)}
      .add-ws-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.9}
      .add-ws-scrim{position:absolute;inset:0;background:linear-gradient(180deg,rgba(15,15,16,.72),rgba(15,15,16,.86))}
      .add-ws-in{position:relative;text-align:center}
      .add-ws-lede{max-width:640px;margin:16px auto 0;color:rgba(255,255,255,.82);font-size:clamp(16px,2.2vw,19px)}
      .add-ws-meta{font-family:var(--font-mono,monospace);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.6);margin-top:18px}
      .add-ws-cta{margin-top:30px}
      .btn-white{display:inline-flex;align-items:center;gap:8px;background:#fff;color:var(--ink);font-weight:500;font-size:15.5px;padding:15px 26px;border-radius:999px;text-decoration:none}
      .add-pdf{background:var(--bg-2)}
      .add-pdf-grid{display:grid;gap:28px;align-items:center}
      @media(min-width:820px){.add-pdf-grid{grid-template-columns:1fr 420px}}
      .add-pdf h3{margin:10px 0}
      .add-pdf-sub{color:var(--muted);max-width:42ch}
      .add-form{display:flex;flex-direction:column;gap:10px;max-width:420px}
      .add-form input{width:100%;padding:14px 16px;font-size:16px;border:1px solid var(--line-2,rgba(15,15,16,.14));border-radius:999px;font-family:inherit}
      .add-fine{font-size:12px;color:var(--muted)}
      .add-err{color:#b23b3b;font-size:13px}
      .add-modal{position:fixed;inset:0;z-index:200;display:none;align-items:center;justify-content:center;padding:20px}
      .add-modal.open{display:flex}
      .add-scrim{position:absolute;inset:0;background:rgba(15,15,16,.45)}
      .add-dialog{position:relative;max-width:440px;width:100%;padding:32px 28px;text-align:center;background:#fff;border-radius:22px;box-shadow:0 30px 80px rgba(15,15,16,.18)}
      .add-dialog h3{margin:8px 0 12px}.add-dialog p{color:var(--ink-2);margin-bottom:22px}
      .add-x{position:absolute;top:10px;right:12px;width:32px;height:32px;background:none;border:none;font-size:24px;color:var(--muted);cursor:pointer}
      .add-dismiss{display:block;margin:14px auto 0;background:none;border:none;color:var(--muted);font-size:13.5px;cursor:pointer;font-family:inherit}
      .add-confirmed{text-align:left}
    `}</style>

    {/* ── Behavior: UTM/pixel/webhook, buy clicks, forms, promo modal ── */}
    <script>
      import { captureUtms, appendUtms } from '../lib/utm';
      import { initiateCheckout, viewContent } from '../lib/pixel';
      import { submitLead } from '../lib/lead';

      captureUtms();
      viewContent('Sales Page');

      // Kajabi buy links: append UTMs + InitiateCheckout
      document.querySelectorAll<HTMLAnchorElement>('a[data-kajabi]').forEach((a) => {
        if (a.dataset.todo !== 'true') a.href = appendUtms(a.href);
      });
      document.addEventListener('click', (e) => {
        const a = (e.target as HTMLElement)?.closest?.('a[data-kajabi]');
        if (!a) return;
        initiateCheckout(Number((a as HTMLElement).dataset.offerValue || 0), (a as HTMLElement).dataset.offerName || 'offer');
      });

      // Lead forms (footer PDF, etc.)
      document.querySelectorAll<HTMLFormElement>('form[data-lead]').forEach((form) => {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const data = new FormData(form);
          const email = String(data.get('email') || '').trim();
          const name = String(data.get('name') || '').trim();
          const err = form.querySelector<HTMLElement>('.add-err');
          if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) { if (err) { err.textContent = 'Please enter a valid email.'; err.hidden = false; } return; }
          if (err) err.hidden = true;
          const btn = form.querySelector('button'); if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
          await submitLead({ name, email, tags: (form.dataset.tags || '').split('|').filter(Boolean), pixelName: form.dataset.pixel });
          const title = (form.dataset.title || 'Got it, {name}.').replace('{name}', name || 'friend');
          form.innerHTML = `<div class="add-confirmed"><h3>${title}</h3><p>${form.dataset.body || ''}</p><a class="btn-dark" href="${form.dataset.next || '/quiz'}">${form.dataset.nextLabel || 'Take the free quiz →'}</a></div>`;
        });
      });

      // Promo modal: 5s value offer + exit intent
      const modal = document.getElementById('promo-modal');
      if (modal) {
        const V = 'pl_promo_value', X = 'pl_promo_exit';
        const vv = modal.querySelector<HTMLElement>('[data-variant="value"]')!;
        const xv = modal.querySelector<HTMLElement>('[data-variant="exit"]')!;
        let open = false;
        const seen = (k: string) => { try { return sessionStorage.getItem(k) === '1'; } catch { return false; } };
        const show = (which: 'value' | 'exit', key: string) => {
          if (open || seen(key)) return; open = true; try { sessionStorage.setItem(key, '1'); } catch {}
          vv.hidden = which !== 'value'; xv.hidden = which !== 'exit'; modal.classList.add('open'); document.body.style.overflow = 'hidden';
        };
        const close = () => { open = false; modal.classList.remove('open'); document.body.style.overflow = ''; };
        setTimeout(() => show('value', V), 5000);
        let inPage = false;
        document.addEventListener('mousemove', () => (inPage = true), { once: true });
        document.addEventListener('mouseout', (e) => { if (inPage && !e.relatedTarget && (e as MouseEvent).clientY <= 0) show('exit', X); });
        modal.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', close));
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && open) close(); });
      }
    </script>
  </body>
</html>
