---
/**
 * PHASE 2 — Sales homepage (phonelicense.co/).
 * Rebuilt from the approved copy in the current live page, in the shared design
 * system, plus the Phase 2 additions: Two-Door section after the hero,
 * Pass/Prove/Verify, week-by-week map, no-subscription pricing, FAQ (incl. the
 * "already has a phone" reset answer), config testimonials, footer PDF capture,
 * and an exit-intent modal → quiz.
 */
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionHead from '../components/SectionHead.astro';
import KajabiLink from '../components/KajabiLink.astro';
import Faq from '../components/Faq.astro';
import ExitModal from '../components/ExitModal.astro';
import StickyCta from '../components/StickyCta.astro';
import { site } from '../config/site';
import { testimonials } from '../config/testimonials';

const included = [
  {
    h: 'The Road Test',
    d: 'Each module ends with a hands-on checklist your teen completes on the device — and you verify. No more “I get it, I get it.”',
  },
  { h: 'Video lessons', d: 'Six modules, studio-shot. Fast-paced, specific, non-preachy — parents feel supported, teens feel respected.' },
  { h: 'The License', d: 'A digital certificate with a unique ID — earned, trackable, renewable. Optional printed wallet card.' },
  { h: 'The Family Agreement', d: 'A 9-section template covering sleep, school, content, conflict, repair — and parent commitments. Signed, not just talked about.' },
  { h: 'The Issuance Ceremony', d: 'Script, parent statement, optional spiritual covenant. The handoff your kid actually remembers.' },
  { h: '90-day Renewal', d: 'A short re-test, agreement review, and privilege adjustments. Trust earned, then renewed.' },
];

const weeks = [
  { w: 'Week 0', h: 'Orientation', d: 'Why a license, not a permission slip. Parents learn the framework; the phone arrives locked down and unlocks as they pass.' },
  { w: 'Week 1', h: 'The Rules of the Road', d: 'Attention, habit loops, notifications. The phone is a tool, not a slot machine.' },
  { w: 'Week 2', h: 'The Social World', d: 'Group chats, face-to-face vs. text, and the social cost of being the one who logs off.' },
  { w: 'Week 3', h: 'Sleep & the Spiral', d: 'Late-night scrolling, secrecy, and the case for a phone-free morning. Build a charging station outside the bedroom.' },
  { w: 'Week 4', h: 'When Things Go Wrong', d: 'Pornography, predators, scams, bullying — what to do in the moment, who to tell, how to recover without shame.' },
  { w: 'Weeks 5–6', h: 'Agreement & Issuance', d: 'Audits, repair-after-failure, expanding privileges — then the family agreement, final exam, and the issuance ceremony.' },
];

const beforeAfter = {
  before: [
    'Constant arguments about screen time',
    'Vague, inconsistent rules',
    'Anxiety about what they’re seeing',
    'Parents and teens on opposite teams',
    'No plan for when something goes wrong',
  ],
  after: [
    'A signed agreement everyone refers back to',
    'Rules earned, not imposed',
    'Clear protocols when things go sideways',
    'Parent and teen facing the problem together',
    'Renewable trust, on a 90-day cadence',
  ],
};

const faqs = [
  {
    q: 'My kid already has a phone — is this still for us?',
    a: 'Absolutely. About half the families here are starting over. Nothing gets confiscated — the phone gets <b>re-issued under a new agreement they earn</b>. You get the exact reset conversation and a calm, week-by-week path back to trust, without a standoff.',
  },
  {
    q: 'Is there a subscription?',
    a: 'No. It’s a <b>one-time purchase with lifetime access</b> — yours forever, for every kid in your family, now and later.',
  },
  {
    q: 'What ages is this for?',
    a: 'Built for the first-phone window and the reset years — roughly ages 10–16. Younger or older, the framework still works; you’ll just move faster or slower through the weeks.',
  },
  {
    q: 'Is it faith-based?',
    a: 'It works for any family. Spiritual elements (like the optional covenant in the issuance ceremony) are exactly that — optional. Use them or skip them.',
  },
  {
    q: 'What exactly do we get?',
    a: 'Six video modules, hands-on Road Tests, the digital License + ID, the 9-section Family Agreement, the Issuance Ceremony script, and the 90-day Renewal. Everything you need to make the handoff a real rite of passage.',
  },
  {
    q: 'How long does it take?',
    a: 'About a 2-hour commitment spread over six weeks — designed to feel like Driver’s Ed: structured, practical, and impossible to fake your way through. Go at your own pace.',
  },
];
---

<Base viewContent="Sales Page">
  <Nav cta={{ label: 'Start — $49', href: '#pricing' }} />

  <main>
    {/* ── Hero ── */}
    <section class="section hero">
      <div class="wrap">
        <h1>
          You wouldn’t hand your kid car keys without training.
          <span class="accent">Why hand them a phone without it?</span>
        </h1>
        <p class="lede">
          A parent + teen course that turns phone access into earned trust — with
          quizzes, a family agreement, and a real certificate.
          <br /><b>{site.twoAudienceLine}</b>
        </p>
        <div class="cta-row">
          <KajabiLink offerId="course" variant="primary" class="lg">Start Phone License — $49</KajabiLink>
          <a href="/quiz" class="btn btn-ghost lg">See if they’re ready →</a>
        </div>
        <ul class="trust">
          <li>2-hour commitment over 6 weeks</li>
          <li>One-time · yours forever</li>
          <li>Certificate included</li>
        </ul>
      </div>
    </section>

    {/* ── Two-Door — directly after the hero ── */}
    <section class="section band-2">
      <div class="wrap">
        <SectionHead eyebrow="Two doors, one path">
          Two kinds of families end up here. <span class="accent">It works for both.</span>
        </SectionHead>
        <div class="doors">
          <div class="card door">
            <p class="mono">First phone</p>
            <h3>The path to a confident yes.</h3>
            <p>
              You haven’t handed it over yet — and you want the first phone to
              start on trust, not guesswork. Phone License gives you the agreement,
              the settings, and the handoff conversation so you can say yes without
              second-guessing.
            </p>
          </div>
          <div class="card door highlight">
            <p class="mono">A fresh start</p>
            <h3>Start over without taking it away.</h3>
            <p>
              They’ve had the phone a while and the boundaries slipped. Here’s the
              relief: <b>nothing gets confiscated.</b> The phone gets re-issued
              under a new agreement they earn — calm, clear, and mutual.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── The problem → the plan ── */}
    <section class="section" id="how">
      <div class="wrap">
        <SectionHead eyebrow="The middle path">From power struggle to shared plan.</SectionHead>
        <div class="triad">
          <div class="card step">
            <p class="mono">01 · The fight</p>
            <h4>“Get off your phone.”</h4>
            <p>Same argument every night. Vague rules. Constant negotiation. Nobody wins.</p>
          </div>
          <div class="card step">
            <p class="mono">02 · The fear</p>
            <h4>What they’re seeing — and not telling you.</h4>
            <p>Group chats, late-night spirals, content you can’t unsee. The stakes feel high and the playbook is missing.</p>
          </div>
          <div class="card step">
            <p class="mono">03 · The plan</p>
            <h4>A shared framework, not a power struggle.</h4>
            <p>Phone License gives families a structured path. Same team, same rules, same finish line.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ── Pass / Prove / Verify ── */}
    <section class="section band-ink" id="course">
      <div class="wrap">
        <SectionHead eyebrow="How it works">
          Pass. Prove. <span class="accent">Verify.</span>
        </SectionHead>
        <p class="ppv-sub">
          Three steps, repeated for six weeks. Designed like Driver’s Ed —
          structured, practical, and impossible to fake your way through.
        </p>
        <div class="ppv">
          <div class="ppv-cell">
            <span class="num">01</span>
            <h4>Pass</h4>
            <p>Watch short modules together — 6–12 minutes each. Micro-quizzes prove they actually got it. No lecture, no panic — just real situations and clear rules.</p>
          </div>
          <div class="ppv-cell">
            <span class="num">02</span>
            <h4>Prove</h4>
            <p>Road Tests prove they can <i>do</i> it — turn on Screen Time, set downtime, build a no-phone zone, set up Medical ID. Hands-on, on the actual device.</p>
          </div>
          <div class="ppv-cell">
            <span class="num">03</span>
            <h4>Verify</h4>
            <p>Parents click “verified.” In the final week the family signs the agreement, the teen takes the situational exam, and the phone is officially issued.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ── What's included ── */}
    <section class="section">
      <div class="wrap">
        <SectionHead eyebrow="What’s included">Tangible, not theoretical.</SectionHead>
        <div class="grid-3">
          {included.map((it) => (
            <div class="card feat">
              <h4>{it.h}</h4>
              <p>{it.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── Curriculum week map ── */}
    <section class="section band-2">
      <div class="wrap">
        <SectionHead eyebrow="The curriculum">
          Six weeks. Driver’s Ed for the device that <span class="accent">actually drives their life.</span>
        </SectionHead>
        <div class="weeks">
          {weeks.map((wk) => (
            <div class="week">
              <span class="wk mono">{wk.w}</span>
              <div>
                <h4>{wk.h}</h4>
                <p>{wk.d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── The shift (before/after) ── */}
    <section class="section">
      <div class="wrap">
        <SectionHead eyebrow="The shift">One team. One playbook. One license.</SectionHead>
        <div class="shift">
          <div class="card ba before">
            <p class="mono">Before · same fight, different night</p>
            <ul>{beforeAfter.before.map((x) => <li>{x}</li>)}</ul>
          </div>
          <div class="card ba after">
            <p class="mono">After · one team</p>
            <ul>{beforeAfter.after.map((x) => <li>{x}</li>)}</ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── Meet your guides ── */}
    <section class="section band-2">
      <div class="wrap">
        <SectionHead eyebrow="Meet your guides">The research meets the rhythm.</SectionHead>
        <div class="guides">
          <div class="card guide">
            <img src="/assets/darren.jpg" alt="Dr. Darren Whitehead" width="88" height="88" />
            <div>
              <p class="mono">The Expert</p>
              <h4>Dr. Darren Whitehead <span class="cred">D.Min.</span></h4>
              <p>Founding pastor of Church of the City (Nashville) and author of <i>The Digital Fast</i> — the playbook thousands of families and churches use to reset their relationship with their phones.</p>
            </div>
          </div>
          <div class="card guide">
            <img src="/assets/jeff-family.jpg" alt="Jefferson & Alyssa Bethke" width="88" height="88" />
            <div>
              <p class="mono">The Family Builder</p>
              <h4>Jefferson Bethke</h4>
              <p>#1 NYT-bestselling author and dad of four. With his wife Alyssa, he’s spent a decade helping families build rhythms over hustle — reaching 30M+ readers and listeners from Leipers Fork, Tennessee.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Testimonials (config-driven) ── */}
    {testimonials.length > 0 && (
      <section class="section">
        <div class="wrap">
          <SectionHead eyebrow="From families">The drive home they talk about.</SectionHead>
          <div class="grid-3">
            {testimonials.map((t) => (
              <figure class="card quote">
                <blockquote>“{t.quote}”</blockquote>
                <figcaption>
                  <b>{t.name}</b> · {t.detail}
                  {t.mock && <span class="mock">sample</span>}
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* ── Pricing ── */}
    <section class="section band-2" id="pricing">
      <div class="wrap">
        <SectionHead eyebrow="Pricing">
          Two ways in. <span class="accent">One outcome.</span>
        </SectionHead>
        <p class="price-sub">
          Perfect for a first phone — or a reset for a phone you’ve already given.
          <b> No subscription. One-time, yours forever.</b>
        </p>
        <div class="tiers">
          <div class="card tier">
            <p class="mono">Core</p>
            <p class="price">$49<span>one-time · lifetime access</span></p>
            <ul class="incl">
              <li>Full course access — 6 modules</li>
              <li>Digital Family Agreement template</li>
              <li>Digital certificate + License ID</li>
            </ul>
            <KajabiLink offerId="course" variant="dark">Start with Core</KajabiLink>
            <p class="best">Best for: families starting a first phone or doing a reset.</p>
          </div>
          <div class="card tier featured">
            <span class="ribbon">Most chosen</span>
            <p class="mono">Premium Kit</p>
            <p class="price">$79<span>one-time · everything in Core, plus…</span></p>
            <ul class="incl">
              <li>Everything in Core</li>
              <li>Issuance Ceremony script + assets</li>
              <li>90-day Renewal mini-course</li>
              <li>Bonus: Social Media Readiness module</li>
            </ul>
            <KajabiLink offerId="premiumKit" variant="primary">Get the Premium Kit</KajabiLink>
            <p class="best">Best for: families who want the rite-of-passage moment to land hard.</p>
          </div>
        </div>
        <p class="quiz-nudge">
          Not sure yet? <a href="/quiz">Take the free 3-minute Readiness Assessment →</a>
        </p>
      </div>
    </section>

    {/* ── FAQ ── */}
    <section class="section" id="faq">
      <div class="wrap">
        <SectionHead eyebrow="Questions">The ones parents actually ask.</SectionHead>
        <Faq items={faqs} name="home-faq" />
      </div>
    </section>

    {/* ── Final CTA ── */}
    <section class="section">
      <div class="wrap final band-ink">
        <h2>Earn the phone. <span class="accent">Keep the trust.</span></h2>
        <p class="lede">Whether it’s their first phone or a fresh start on the one they already have — start the plan today.</p>
        <div class="cta-row center">
          <KajabiLink offerId="course" variant="primary" class="lg">Start Phone License — $49</KajabiLink>
          <a href="/quiz" class="btn btn-ghost lg">Take the free quiz →</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <ExitModal />

  <StickyCta title="Phone License" line="One-time · yours forever">
    <KajabiLink offerId="course" variant="primary">Start — $49</KajabiLink>
  </StickyCta>
</Base>

<style>
  .hero {
    text-align: center;
    padding-block: 72px 48px;
  }
  .hero .lede {
    margin: 18px auto 0;
    max-width: 620px;
  }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }
  .hero .cta-row {
    justify-content: center;
  }
  .cta-row.center {
    justify-content: center;
  }
  :global(.btn.lg) {
    padding: 16px 28px;
    font-size: 16px;
  }
  .trust {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 22px;
    margin-top: 26px;
    font-size: 13.5px;
    color: var(--muted);
    font-family: var(--font-mono);
    letter-spacing: 0.03em;
  }
  .trust li {
    position: relative;
  }
  .trust li:not(:first-child)::before {
    content: '·';
    position: absolute;
    left: -13px;
  }

  .doors,
  .guides,
  .shift {
    display: grid;
    gap: 20px;
    margin-top: 36px;
  }
  .door h3,
  .step h4,
  .feat h4,
  .tier .mono {
    margin-bottom: 8px;
  }
  .door {
    padding: 28px;
  }
  .door.highlight {
    background: var(--blue-tint);
    border-color: var(--blue-tint-2);
  }
  .door p:last-child,
  .step p:last-child {
    color: var(--ink-2);
    margin-top: 8px;
  }

  .triad,
  .grid-3 {
    display: grid;
    gap: 20px;
    margin-top: 36px;
  }
  .step,
  .feat,
  .quote {
    padding: 24px;
  }
  .feat p,
  .quote blockquote {
    color: var(--ink-2);
    margin-top: 8px;
  }

  .ppv-sub,
  .price-sub {
    max-width: 640px;
    margin: 14px auto 0;
    text-align: center;
    color: var(--muted);
  }
  .band-ink .ppv-sub {
    color: rgba(255, 255, 255, 0.66);
  }
  .ppv {
    display: grid;
    gap: 24px;
    margin-top: 40px;
  }
  .ppv-cell .num {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--blue-on-dark);
    letter-spacing: 0.1em;
  }
  .ppv-cell h4 {
    margin: 10px 0 8px;
  }
  .ppv-cell p {
    color: rgba(255, 255, 255, 0.72);
  }

  .weeks {
    margin-top: 36px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .week {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 16px;
    padding: 20px 0;
    border-top: 1px solid var(--line);
    align-items: start;
  }
  .week .wk {
    color: var(--blue-deep);
    padding-top: 3px;
  }
  .week h4 {
    margin-bottom: 4px;
  }
  .week p {
    color: var(--ink-2);
  }

  .ba {
    padding: 26px;
  }
  .ba ul {
    list-style: none;
    margin-top: 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .ba li {
    padding-left: 26px;
    position: relative;
  }
  .before li::before {
    content: '✕';
    position: absolute;
    left: 0;
    color: var(--red-pin);
  }
  .after {
    background: var(--blue-tint);
    border-color: var(--blue-tint-2);
  }
  .after li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--blue-deep);
  }

  .guide {
    display: flex;
    gap: 18px;
    padding: 24px;
    align-items: flex-start;
  }
  .guide img {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    flex: none;
  }
  .guide .cred {
    font-size: 13px;
    color: var(--muted);
    font-weight: 500;
  }
  .guide p:last-child {
    color: var(--ink-2);
    margin-top: 6px;
    font-size: 15px;
  }

  .quote blockquote {
    font-size: 17px;
    line-height: 1.5;
  }
  .quote figcaption {
    margin-top: 16px;
    font-size: 14px;
    color: var(--muted);
  }
  .mock {
    display: inline-block;
    margin-left: 6px;
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--line-2);
    border-radius: var(--r-pill);
    padding: 1px 6px;
  }

  .tiers {
    display: grid;
    gap: 20px;
    margin-top: 36px;
    align-items: start;
  }
  .tier {
    padding: 28px;
    position: relative;
  }
  .tier.featured {
    border-color: var(--blue);
    box-shadow: var(--shadow-md);
  }
  .ribbon {
    position: absolute;
    top: -11px;
    left: 28px;
    background: var(--blue);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: var(--r-pill);
  }
  .price {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 40px;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin: 6px 0 18px;
    line-height: 1;
  }
  .price span {
    display: block;
    font-size: 13px;
    font-weight: 400;
    color: var(--muted);
    letter-spacing: 0;
    margin-top: 6px;
  }
  .incl {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 22px;
  }
  .incl li {
    padding-left: 24px;
    position: relative;
  }
  .incl li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--blue-deep);
  }
  .tier :global(.btn) {
    width: 100%;
  }
  .best {
    font-size: 13px;
    color: var(--muted);
    margin-top: 14px;
  }
  .quiz-nudge {
    text-align: center;
    margin-top: 28px;
    color: var(--muted);
  }
  .quiz-nudge a {
    color: var(--blue-deep);
    font-weight: 500;
  }

  .final {
    border-radius: var(--r-lg);
    padding: 56px 32px;
    text-align: center;
  }
  .final .lede {
    color: rgba(255, 255, 255, 0.72);
    max-width: 560px;
    margin: 16px auto 0;
  }

  @media (min-width: 720px) {
    .doors,
    .shift,
    .guides {
      grid-template-columns: 1fr 1fr;
    }
    .triad,
    .grid-3,
    .ppv {
      grid-template-columns: repeat(3, 1fr);
    }
    .tiers {
      grid-template-columns: 1fr 1fr;
      max-width: 820px;
      margin-inline: auto;
    }
  }
</style>
