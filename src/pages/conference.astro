---
/**
 * PHASE 4 — /conference · "Parenting the Screen Age" (the money page).
 * Every state (interest / earlybird / almostfull / soldout) is driven by
 * events.ts. Seat counts render only when truthful. In interest state the money
 * CTAs become first-access capture (handled by EventCta). Placeholders per the
 * README "do not ship as-is" list are flagged inline.
 */
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionHead from '../components/SectionHead.astro';
import SeatChip from '../components/SeatChip.astro';
import StatusBadge from '../components/StatusBadge.astro';
import Faq from '../components/Faq.astro';
import EventCta from '../components/EventCta.astro';
import StickyCta from '../components/StickyCta.astro';
import { events, seatChipView, priceView, finalHeadline, stickyLine, icsDataUri } from '../config/events';
import { conference as c } from '../config/event-content';
import { testimonials } from '../config/testimonials';

const e = events['conference'];
const chip = seatChipView(e);
const price = priceView(e);
const anchors = [
  { label: 'This year', href: '#changed' },
  { label: 'Agenda', href: '#agenda' },
  { label: 'Hosts', href: '#hosts' },
  { label: 'Tickets', href: '#tickets' },
];
const inclusions = [
  'Admits two — bring your partner or co-parent',
  'The full day + all materials',
  'Lunch together, included',
  'Your written family plan to take home',
  'Supper in Leipers Fork that evening',
];
---

<Base title={`${e.title} ${e.edition} — Phone License`} viewContent="Conference">
  <Nav yearMark={e.edition} anchors={anchors} cta={{ label: 'Tickets', href: '#tickets' }} />

  <main>
    {/* ── Hero ── */}
    <section class="section hero">
      <div class="wrap">
        <span class="pill mono">{e.edition} Edition · Once a year</span>
        <h1>{e.title} <span class="accent">Workshop</span></h1>
        <p class="lede italic">{c.heroLede}</p>
        <ul class="dots">
          <li>{e.dateDisplay}</li>
          <li>{e.venue} · {e.city}</li>
          <li>Capped at {e.capacity} couples</li>
        </ul>
        <div class="hero-cta">
          <EventCta event={e} variant="primary" />
          <a href="#agenda" class="btn btn-ghost">See the day →</a>
        </div>
        {chip && <div class="hero-chip"><SeatChip copy={chip.copy} tone={chip.tone} fill={chip.fill} /></div>}
        <p class="hosts-line mono">Hosted by Jefferson &amp; Alyssa Bethke and Dr. Darren Whitehead</p>
        <a class="ics" href={icsDataUri(e)} download={`phone-license-${e.slug}-${e.edition}.ics`}>＋ Add to calendar</a>
      </div>
    </section>

    {/* ── Felt need ── */}
    <section class="section band-2 felt">
      <div class="wrap">
        <p class="eyebrow">Be honest</p>
        {c.feltNeed.map((q, i) => (
          <p class="felt-q" style={`opacity:${1 - i * 0.2}`}>{q}</p>
        ))}
        <p class="felt-turn">
          You’re not failing. The terrain changed — and nobody briefed you.
          <span class="accent"> That’s what this day is for.</span>
        </p>
      </div>
    </section>

    {/* ── What changed this year ── */}
    <section class="section band-ink" id="changed">
      <div class="wrap">
        <span class="stamp">Refreshed for {e.edition}</span>
        <SectionHead eyebrow="What changed this year">
          Updated every year — because <span class="accent on-dark">next year this list is different.</span>
        </SectionHead>
        <div class="dossier">
          {c.whatChanged.map((w) => (
            <div class="cell">
              <div class="cell-top">
                <span class="mono idx">{w.index} / 06</span>
                <span class:list={['tag', `tag-${w.tag.toLowerCase()}`]}>{w.tag}</span>
              </div>
              <h4>{w.h}</h4>
              <p>{w.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── Why both of you ── */}
    <section class="section">
      <div class="wrap">
        <SectionHead eyebrow="Why both of you">Come as a team. Leave with one plan.</SectionHead>
        <div class="grid-3">
          {c.whyBoth.map((w) => (
            <div class:list={['card wb', w.highlight && 'hl']}>
              <h4>{w.h}</h4>
              <p>{w.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── Agenda ── */}
    <section class="section band-2" id="agenda">
      <div class="wrap">
        <SectionHead eyebrow="The day">One room. No lectures.</SectionHead>
        <div class="agenda">
          {c.agenda.map((col) => (
            <div class="acol">
              <p class="mono acol-h">{col.title}</p>
              {col.slots.map((s) => (
                <div class="slot">
                  <span class="time mono">{s.time}</span>
                  <span class="slot-h">{s.h}</span>
                  {s.note && <span class="slot-note mono">{s.note}</span>}
                </div>
              ))}
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── The Signing (emotional peak) ── */}
    <section class="signing" style="--img:url('/assets/couple-embrace.jpg')">
      <div class="scrim"></div>
      <div class="wrap signing-in">
        <p class="mono">4:30 PM · The Signing</p>
        <h2>The moment it becomes real.</h2>
        <p>Both of you sign the plan you built together — the five minutes couples talk about on the drive home.</p>
      </div>
    </section>

    {/* ── Come back every year (alumni slot) ── */}
    <section class="section">
      <div class="wrap">
        <SectionHead eyebrow="Come back every year">The course is day one. This is every year after.</SectionHead>
        <div class="rhythm">
          <div class="card rc"><p class="mono">Spring</p><h4>The Summit</h4><p>Virtual half-day, one topic.</p></div>
          <div class="card rc dark"><p class="mono">Fall</p><h4>The Workshop</h4><p>The in-person annual briefing.</p></div>
          <div class="card rc"><p class="mono">Every year</p><h4>We do it again</h4><p>Because it will all have changed.</p></div>
        </div>
        <div class="alumni card">
          <div>
            <p class="mono">Came last year?</p>
            <h4>Returning couples save <span class="accent">{c.alumniDiscount}% </span></h4>
            <p class="alumni-note">Your seat from last year gets you the alumni rate. <b>(TODO: set real discount.)</b></p>
          </div>
        </div>
      </div>
    </section>

    {/* ── Hosts ── */}
    <section class="section band-2" id="hosts">
      <div class="wrap">
        <SectionHead eyebrow="Your hosts">The research meets the rhythm.</SectionHead>
        <div class="hosts">
          <div class="card host">
            <img src="/assets/darren.jpg" alt="Dr. Darren Whitehead" width="72" height="72" />
            <div><span class="mono">The Expert</span><h4>Dr. Darren Whitehead</h4><p>Pastor, author of <i>The Digital Fast</i>, researcher on the future of the family.</p></div>
          </div>
          <div class="card host">
            <img src="/assets/jeff-family.jpg" alt="Jefferson & Alyssa Bethke" width="72" height="72" />
            <div><span class="mono">The Family Builders</span><h4>Jefferson &amp; Alyssa Bethke</h4><p>NYT-bestselling authors and parents of four, building family rhythms from Leipers Fork.</p></div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Testimonials ── */}
    {testimonials.length > 0 && (
      <section class="section band-ink">
        <div class="wrap">
          <SectionHead eyebrow="From the room">The drive home they talk about.</SectionHead>
          <div class="grid-3">
            {testimonials.map((t) => (
              <figure class="tcard">
                <blockquote>“{t.quote}”</blockquote>
                <figcaption>{t.name} · {t.detail}{t.mock && <span class="mock">sample</span>}</figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* ── Who this is for ── */}
    <section class="section">
      <div class="wrap">
        <SectionHead eyebrow="Honestly">Who this day is for.</SectionHead>
        <div class="forwho">
          <div class="card fw yes">
            <p class="mono">This is for you if…</p>
            <ul>{c.forYou.map((x) => <li>{x}</li>)}</ul>
          </div>
          <div class="card fw no">
            <p class="mono">It’s not for you if…</p>
            <ul>{c.notForYou.map((x) => <li>{x}</li>)}</ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── Pricing ── */}
    <section class="section band-2" id="tickets">
      <div class="wrap">
        <SectionHead eyebrow="Tickets">One ticket. Admits two.</SectionHead>
        <div class="pricecard card">
          {price.pin && <span class:list={['pin', `pin-${price.pin.tone}`]}>{price.pin.label}</span>}
          <p class="mono">Couple ticket · admits two</p>
          <p class="amount">
            {price.amount}
            {price.struck && <span class="struck">{price.struck}</span>}
            <span class="unit">{price.note}</span>
          </p>
          <ul class="incl">{inclusions.map((x) => <li>{x}</li>)}</ul>
          <EventCta event={e} variant="dark" />
        </div>

        <div class="guarantee card">
          <span class="seal" aria-hidden="true">✓</span>
          <div>
            <h4>The Aligned Plan Guarantee</h4>
            <p>If it’s not for you, tell us at the door — full refund, no form, no fuss. <b>(Pending business sign-off.)</b></p>
          </div>
        </div>
        <p class="why200">Why only {e.capacity} couples? The afternoon is a lab, not a lecture — past {e.capacity} phones, that breaks.</p>
      </div>
    </section>

    {/* ── Scholarship ── */}
    <section class="section">
      <div class="wrap scholarship card">
        <span class="seal" aria-hidden="true">♥</span>
        <div>
          <p class="mono">Send a couple</p>
          <h4>Sponsor a scholarship couple.</h4>
          <p>Some families can’t swing a ticket. Cover one. It’s a mission, not an upsell — ask us at checkout or by email.</p>
        </div>
      </div>
    </section>

    {/* ── FAQ ── */}
    <section class="section band-2">
      <div class="wrap">
        <SectionHead eyebrow="Questions">Before you commit.</SectionHead>
        <Faq items={c.faqs} name="conf-faq" />
      </div>
    </section>

    {/* ── Final CTA ── */}
    <section class="section">
      <div class="wrap final band-ink">
        <h2>{finalHeadline(e)}</h2>
        <p class="lede">Whether it’s their first phone or a fresh start — one aligned plan for the year ahead.</p>
        <div class="final-cta"><EventCta event={e} variant="primary" /></div>
        <p class="fine mono">The course is day one · this is every year after</p>
      </div>
    </section>
  </main>

  <Footer />

  <StickyCta title={`${e.title} ${e.edition}`} line={stickyLine(e)}>
    <a href="#tickets" class="btn btn-primary">Tickets</a>
  </StickyCta>
</Base>

<style>
  .hero {
    text-align: center;
    padding-block: 64px 40px;
  }
  .pill {
    display: inline-block;
    padding: 6px 14px;
    border: 1px solid var(--line-2);
    border-radius: var(--r-pill);
    color: var(--blue-deep);
  }
  .hero h1 {
    margin-top: 18px;
  }
  .lede.italic {
    font-style: italic;
    color: var(--blue-deep);
    margin-top: 14px;
  }
  .dots {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 20px;
    margin-top: 20px;
    font-size: 14px;
    color: var(--muted);
  }
  .dots li {
    position: relative;
  }
  .dots li:not(:first-child)::before {
    content: '·';
    position: absolute;
    left: -12px;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 26px;
  }
  .hero-chip {
    display: flex;
    justify-content: center;
    margin-top: 20px;
  }
  .hosts-line {
    margin-top: 22px;
    color: var(--muted);
  }
  .ics {
    display: inline-block;
    margin-top: 12px;
    font-size: 13px;
    color: var(--blue-deep);
  }

  .felt {
    text-align: center;
  }
  .felt-q {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(20px, 3.5vw, 30px);
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-top: 12px;
  }
  .felt-turn {
    max-width: 620px;
    margin: 28px auto 0;
    font-size: 18px;
    color: var(--ink-2);
  }

  .stamp {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--blue-on-dark);
    border: 1px dashed rgba(255, 255, 255, 0.3);
    background: rgba(79, 131, 204, 0.12);
    padding: 5px 12px;
    border-radius: 8px;
    transform: rotate(-2deg);
    margin-bottom: 20px;
  }
  .dossier {
    display: grid;
    gap: 16px;
    margin-top: 36px;
  }
  .cell {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--r-sm);
    padding: 20px;
  }
  .cell-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }
  .cell .idx {
    color: rgba(255, 255, 255, 0.4);
  }
  .cell h4 {
    color: #fff;
    margin-bottom: 6px;
  }
  .cell p {
    color: rgba(255, 255, 255, 0.68);
    font-size: 14.5px;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.1em;
    padding: 2px 7px;
    border-radius: var(--r-pill);
  }
  .tag-new {
    background: var(--blue);
    color: #fff;
  }
  .tag-rising {
    background: var(--amber-bg);
    color: var(--amber-ink);
  }
  .tag-shift {
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: rgba(255, 255, 255, 0.7);
  }

  .grid-3 {
    display: grid;
    gap: 20px;
    margin-top: 36px;
  }
  .wb,
  .rc {
    padding: 24px;
  }
  .wb h4,
  .rc h4 {
    margin-bottom: 8px;
  }
  .wb.hl {
    background: var(--blue-tint);
    border-color: var(--blue-tint-2);
  }

  .agenda {
    display: grid;
    gap: 24px;
    margin-top: 36px;
  }
  .acol-h {
    color: var(--blue-deep);
    margin-bottom: 8px;
  }
  .slot {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 16px 0;
    border-top: 1px solid var(--line);
  }
  .slot .time {
    color: var(--muted);
    width: 48px;
    flex: none;
  }
  .slot-h {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
  }
  .slot-note {
    margin-left: auto;
    color: var(--blue-deep);
    font-size: 10px;
  }

  .signing {
    position: relative;
    background-image: var(--img);
    background-size: cover;
    background-position: center;
    min-height: 380px;
    display: flex;
    align-items: center;
    color: #fff;
    text-align: center;
  }
  .signing .scrim {
    position: absolute;
    inset: 0;
    background: rgba(15, 15, 16, 0.62);
  }
  .signing-in {
    position: relative;
  }
  .signing-in .mono {
    color: var(--blue-on-dark);
  }
  .signing h2 {
    color: #fff;
    margin: 10px 0;
  }
  .signing p {
    color: rgba(255, 255, 255, 0.82);
    max-width: 520px;
    margin-inline: auto;
  }

  .rhythm {
    display: grid;
    gap: 16px;
    margin-top: 36px;
  }
  .rc.dark {
    background: var(--ink);
    color: #fff;
  }
  .rc.dark h4 {
    color: #fff;
  }
  .alumni {
    margin-top: 20px;
    padding: 24px;
    background: var(--blue-tint);
    border-color: var(--blue-tint-2);
  }
  .alumni-note {
    color: var(--muted);
    font-size: 14px;
    margin-top: 6px;
  }

  .hosts,
  .forwho {
    display: grid;
    gap: 20px;
    margin-top: 36px;
  }
  .host {
    display: flex;
    gap: 16px;
    padding: 22px;
    align-items: flex-start;
  }
  .host img {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    flex: none;
  }
  .host h4 {
    margin: 4px 0;
  }
  .host p {
    color: var(--ink-2);
    font-size: 15px;
  }

  .tcard {
    padding: 4px;
  }
  .tcard blockquote {
    font-size: 17px;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.5;
  }
  .tcard figcaption {
    margin-top: 14px;
    font-size: 13.5px;
    color: rgba(255, 255, 255, 0.55);
  }
  .mock {
    margin-left: 6px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--r-pill);
    padding: 1px 6px;
  }

  .fw {
    padding: 24px;
  }
  .fw ul {
    list-style: none;
    margin-top: 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .fw li {
    padding-left: 26px;
    position: relative;
  }
  .fw.yes {
    background: var(--blue-tint);
    border-color: var(--blue-tint-2);
  }
  .fw.yes li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--blue-deep);
  }
  .fw.no li::before {
    content: '✕';
    position: absolute;
    left: 0;
    color: var(--muted);
  }

  .pricecard {
    position: relative;
    max-width: 460px;
    margin: 36px auto 0;
    padding: 32px 28px;
    text-align: center;
  }
  .pin {
    position: absolute;
    top: -11px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: var(--r-pill);
    white-space: nowrap;
  }
  .pin-blue {
    background: var(--blue);
    color: #fff;
  }
  .pin-amber {
    background: var(--amber-bg);
    color: var(--amber-ink);
  }
  .pin-red {
    background: var(--red-pin);
    color: #fff;
  }
  .amount {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 48px;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin: 8px 0 18px;
    line-height: 1;
  }
  .amount .struck {
    font-size: 22px;
    color: var(--muted);
    text-decoration: line-through;
    margin-left: 10px;
  }
  .amount .unit {
    display: block;
    font-size: 13px;
    font-weight: 400;
    color: var(--muted);
    letter-spacing: 0;
    margin-top: 8px;
  }
  .incl {
    list-style: none;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 22px;
  }
  .incl li {
    padding-left: 24px;
    position: relative;
  }
  .incl li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--blue-deep);
  }
  .pricecard :global(.btn),
  .pricecard :global(.leadform) {
    width: 100%;
    margin-inline: auto;
  }
  .guarantee,
  .scholarship {
    display: flex;
    gap: 18px;
    align-items: flex-start;
    max-width: 620px;
    margin: 20px auto 0;
    padding: 24px;
  }
  .seal {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--blue);
    color: #fff;
    font-size: 18px;
    flex: none;
  }
  .why200 {
    text-align: center;
    max-width: 520px;
    margin: 24px auto 0;
    color: var(--muted);
    font-size: 14.5px;
  }

  .final {
    border-radius: var(--r-lg);
    padding: 56px 32px;
    text-align: center;
  }
  .final .lede {
    color: rgba(255, 255, 255, 0.72);
    max-width: 520px;
    margin: 16px auto 0;
  }
  .final-cta {
    display: flex;
    justify-content: center;
    margin-top: 24px;
  }
  .final .fine {
    color: rgba(255, 255, 255, 0.45);
    margin-top: 20px;
  }

  @media (min-width: 720px) {
    .dossier {
      grid-template-columns: repeat(3, 1fr);
    }
    .grid-3 {
      grid-template-columns: repeat(3, 1fr);
    }
    .agenda,
    .hosts,
    .forwho {
      grid-template-columns: 1fr 1fr;
    }
    .rhythm {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
